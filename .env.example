# Example environment variables file
# Copy this to .env and fill in your actual values

API_PREFIX=/v1
API_TITLE=Bandjacks API

# MITRE ATT&CK Configuration
ATTACK_INDEX_URL=https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/index.json

# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OS_INDEX_NODES=bandjacks_attack_nodes-v1

# ADM Validation
ADM_MODE=schema
ADM_BASE_URL=http://adm-validate:8080
ADM_SPEC_MIN=3.3.0

# LLM API Keys (get these from respective providers)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Redis Configuration for Job Queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_LOCK_TIMEOUT=600
REDIS_HEARTBEAT_INTERVAL=30

# Job Processing Settings
JOB_CLAIM_TTL=300
JOB_HEARTBEAT_TTL=60
WORKER_ID_PREFIX=worker

# Authentication Settings
ENABLE_AUTH=false
OIDC_ISSUER=
OIDC_AUDIENCE=bandjacks-api
JWT_ALGORITHM=RS256
JWT_SECRET=generate-a-strong-secret-key-here
REQUIRE_AUTH_FOR_READS=false